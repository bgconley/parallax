PARALLAX_ENV=development
PARALLAX_API_VERSION=0.1.0
PARALLAX_CONTRACT_VERSION=1.3.0
PARALLAX_DATABASE_URL=postgresql://parallax:parallax_dev_password@postgres:5432/parallax
PARALLAX_HOST_DATABASE_URL=postgresql://parallax:parallax_dev_password@127.0.0.1:15432/parallax
PARALLAX_REDIS_URL=redis://redis:6379/0
PARALLAX_TEMPORAL_ADDRESS=temporal:7233
PARALLAX_OBJECT_STORAGE_ENDPOINT=http://minio:9000
PARALLAX_AUTH_MODE=dev_header
# For PARALLAX_AUTH_MODE=external_bearer, prefer issuer/audience-bound JWKS
# verification. HS256 is retained only for private-alpha/local token tests.
# Production/staging values must come from environment injection or a secret manager.
PARALLAX_AUTH_JWT_SECRET=
PARALLAX_AUTH_JWKS_URL=
PARALLAX_AUTH_JWT_ALGORITHM=HS256
PARALLAX_AUTH_JWT_USER_ID_CLAIM=sub
PARALLAX_AUTH_JWT_ISSUER=
PARALLAX_AUTH_JWT_AUDIENCE=
PARALLAX_RUNTIME_ROOT=/srv/parallax
PARALLAX_POSTGRES_DATA=/srv/parallax/postgres
PARALLAX_POSTGRES_WAL=/srv/parallax/postgres_wal
PARALLAX_OBJECTS_DIR=/srv/parallax/objects
PARALLAX_EXPORTS_DIR=/srv/parallax/exports
PARALLAX_MODELS_DIR=/srv/parallax/models
PARALLAX_HF_CACHE_DIR=/srv/parallax/hf_cache
PARALLAX_LOGS_DIR=/srv/parallax/logs
PARALLAX_OBSERVABILITY_DIR=/srv/parallax/observability
PARALLAX_CONFIG_DIR=/srv/parallax/config
PARALLAX_POSTGRES_BIND=127.0.0.1
PARALLAX_POSTGRES_PORT=15432
PARALLAX_REDIS_BIND=127.0.0.1
PARALLAX_REDIS_PORT=16379
PARALLAX_TEMPORAL_BIND=127.0.0.1
PARALLAX_TEMPORAL_PORT=17233
PARALLAX_TEMPORAL_UI_BIND=127.0.0.1
PARALLAX_TEMPORAL_UI_PORT=18088
PARALLAX_MINIO_BIND=127.0.0.1
PARALLAX_MINIO_PORT=19000
PARALLAX_MINIO_CONSOLE_BIND=127.0.0.1
PARALLAX_MINIO_CONSOLE_PORT=19001
PARALLAX_API_BIND=127.0.0.1
PARALLAX_API_PORT=18000
PARALLAX_CADDY_HTTP_BIND=127.0.0.1
PARALLAX_CADDY_HTTP_PORT=18080
PARALLAX_CADDY_HTTPS_BIND=127.0.0.1
PARALLAX_CADDY_HTTPS_PORT=18443
POSTGRES_DB=parallax
POSTGRES_USER=parallax
POSTGRES_PASSWORD=parallax_dev_password
MINIO_ROOT_USER=parallax_dev
MINIO_ROOT_PASSWORD=parallax_dev_password
