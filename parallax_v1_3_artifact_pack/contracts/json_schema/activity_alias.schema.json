{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.parallax.local/v1.3/ActivityAlias.schema.json",
  "title": "ActivityAlias",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "uuid": {
      "type": "string",
      "format": "uuid"
    },
    "date_time": {
      "type": "string",
      "format": "date-time"
    }
  },
  "properties": {
    "id": {
      "$ref": "#/$defs/uuid"
    },
    "user_id": {
      "$ref": "#/$defs/uuid"
    },
    "activity_id": {
      "$ref": "#/$defs/uuid"
    },
    "alias_text": {
      "type": "string",
      "minLength": 1
    },
    "normalized_alias": {
      "type": "string"
    },
    "source": {
      "type": "string",
      "enum": [
        "user",
        "system_suggested",
        "imported"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "user_confirmed": {
      "type": "boolean"
    },
    "rejected": {
      "type": "boolean"
    },
    "created_at": {
      "$ref": "#/$defs/date_time"
    }
  },
  "required": [
    "id",
    "user_id",
    "activity_id",
    "alias_text",
    "normalized_alias",
    "source",
    "confidence",
    "user_confirmed",
    "rejected",
    "created_at"
  ]
}
