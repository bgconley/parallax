{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.parallax.local/v1.3/common.schema.json",
  "title": "ParallaxCommonDefinitions",
  "$defs": {
    "uuid": {
      "type": "string",
      "format": "uuid"
    },
    "date_time": {
      "type": "string",
      "format": "date-time"
    },
    "non_negative_integer": {
      "type": "integer",
      "minimum": 0
    },
    "confidence_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "timing_mode": {
      "type": "string",
      "enum": [
        "estimate_only",
        "whole_task",
        "checkpointed",
        "routine",
        "calibration",
        "passive"
      ]
    },
    "timing_session_status": {
      "type": "string",
      "enum": [
        "draft",
        "intent_recorded",
        "running",
        "paused",
        "completed_unreviewed",
        "reviewed",
        "discarded",
        "abandoned"
      ]
    },
    "work_mode": {
      "type": "string",
      "enum": [
        "unknown",
        "home",
        "wfh",
        "office",
        "travel",
        "weekend",
        "errand",
        "hybrid"
      ]
    },
    "actor_mode": {
      "type": "string",
      "enum": [
        "solo",
        "assisted",
        "delegated",
        "unknown"
      ]
    },
    "privacy_class": {
      "type": "string",
      "enum": [
        "normal",
        "sensitive",
        "private"
      ]
    },
    "run_quality": {
      "type": "string",
      "enum": [
        "unknown",
        "typical",
        "useful_unusual",
        "assisted",
        "partial",
        "bad_timer",
        "corrupted",
        "do_not_train"
      ]
    },
    "model_inclusion": {
      "type": "string",
      "enum": [
        "not_reviewed",
        "full",
        "active_duration_only",
        "wall_envelope_only",
        "friction_patterns_only",
        "query_evidence_only",
        "exclude"
      ]
    },
    "annotation_input_mode": {
      "type": "string",
      "enum": [
        "text",
        "voice",
        "quick_chip",
        "system_detected",
        "review_note"
      ]
    },
    "annotation_status": {
      "type": "string",
      "enum": [
        "captured",
        "transcription_pending",
        "transcribed",
        "extraction_pending",
        "extracted",
        "needs_confirmation",
        "confirmed",
        "corrected",
        "ignored",
        "redacted",
        "deleted"
      ]
    },
    "timing_event_type": {
      "type": "string",
      "enum": [
        "intent_recorded",
        "session_started",
        "session_paused",
        "session_resumed",
        "session_completed",
        "session_abandoned",
        "checkpoint_started",
        "checkpoint_completed",
        "checkpoint_skipped",
        "annotation_captured",
        "extracted_event_created",
        "active_work_started",
        "active_work_completed",
        "setup_started",
        "setup_completed",
        "resource_detour_started",
        "resource_detour_completed",
        "interruption_started",
        "interruption_completed",
        "waiting_started",
        "waiting_completed",
        "side_quest_started",
        "side_quest_completed",
        "transition_started",
        "transition_completed",
        "bad_timer_marked",
        "scope_changed",
        "user_correction_applied",
        "review_saved",
        "sync_reconciled"
      ]
    },
    "temporal_span_type": {
      "type": "string",
      "enum": [
        "active_work",
        "setup",
        "resource_detour",
        "interruption",
        "waiting",
        "side_quest",
        "start_latency",
        "transition",
        "body_energy",
        "decision_loop",
        "attention_drift",
        "environment_friction",
        "bad_timer",
        "scope_change",
        "other"
      ]
    },
    "friction_category": {
      "type": "string",
      "enum": [
        "none",
        "resource",
        "setup",
        "transition",
        "interruption",
        "waiting",
        "side_quest",
        "decision",
        "attention",
        "body_energy",
        "environment",
        "timer_quality",
        "scope",
        "unknown"
      ]
    },
    "count_policy": {
      "type": "string",
      "enum": [
        "wall_and_active",
        "wall_only",
        "active_only",
        "separate_start_latency",
        "separate_transition",
        "do_not_count",
        "review_required"
      ]
    },
    "confirmation_state": {
      "type": "string",
      "enum": [
        "auto_logged",
        "needs_confirmation",
        "confirmed",
        "corrected",
        "ignored",
        "deferred_to_review"
      ]
    },
    "relationship_kind": {
      "type": "string",
      "enum": [
        "same_as",
        "alias_of",
        "part_of",
        "has_checkpoint",
        "variant_of",
        "related_to",
        "usually_before",
        "usually_after"
      ]
    },
    "model_update_decision_type": {
      "type": "string",
      "enum": [
        "save_useful_run",
        "mark_unusual",
        "save_partial",
        "active_only",
        "friction_only",
        "query_evidence_only",
        "discard_timing_keep_note",
        "discard_all"
      ]
    },
    "prediction_basis": {
      "type": "string",
      "enum": [
        "generic_prior",
        "personal_last_time",
        "personal_rolling_stats",
        "personal_model",
        "hybrid",
        "insufficient_data"
      ]
    },
    "confidence_label": {
      "type": "string",
      "enum": [
        "very_low",
        "low",
        "medium",
        "high"
      ]
    },
    "capture_method": {
      "type": "string",
      "enum": [
        "manual_timer_button",
        "lock_screen_widget",
        "home_screen_widget",
        "watch",
        "voice",
        "quick_chip",
        "shortcut",
        "nfc_tag",
        "calendar_import",
        "system_detected",
        "review_reconstruction",
        "background_signal",
        "api"
      ]
    },
    "capture_trigger": {
      "type": "string",
      "enum": [
        "user_initiated",
        "timer_event",
        "annotation",
        "checkpoint_event",
        "permission_change",
        "geofence_transition",
        "place_visit",
        "radio_fingerprint_change",
        "motion_change",
        "sync_replay",
        "review"
      ]
    },
    "geospatial_source_type": {
      "type": "string",
      "enum": [
        "fused_location",
        "gps",
        "network_location",
        "wifi_derived",
        "wifi_rtt",
        "ble_beacon",
        "ibeacon",
        "uwb",
        "cell",
        "manual_place",
        "geofence",
        "visit",
        "significant_location_change",
        "none"
      ]
    },
    "radio_source_type": {
      "type": "string",
      "enum": [
        "wifi_connected_network",
        "wifi_scan",
        "wifi_rtt",
        "ble_scan",
        "ibeacon",
        "uwb",
        "cell",
        "unknown"
      ]
    },
    "motion_state": {
      "type": "string",
      "enum": [
        "unknown",
        "stationary",
        "walking",
        "running",
        "cycling",
        "driving",
        "in_vehicle",
        "transit",
        "mixed"
      ]
    },
    "place_category": {
      "type": "string",
      "enum": [
        "unknown",
        "home",
        "work",
        "office",
        "kitchen",
        "garage",
        "yard",
        "store",
        "gym",
        "vehicle",
        "public",
        "client_site",
        "medical",
        "school",
        "religious",
        "other"
      ]
    },
    "sensor_availability_state": {
      "type": "string",
      "enum": [
        "available",
        "permission_denied",
        "disabled_by_user",
        "disabled_by_system",
        "unsupported",
        "unavailable",
        "not_requested",
        "stale"
      ]
    },
    "sensor_retention_policy": {
      "type": "string",
      "enum": [
        "do_not_store",
        "derived_only",
        "short_ttl_raw",
        "store_with_consent"
      ]
    },
    "timing_review_flag_type": {
      "type": "string",
      "enum": [
        "possible_forgotten_timer",
        "place_transition",
        "long_idle_gap",
        "impossible_sequence",
        "low_context_quality",
        "privacy_review_required",
        "manual_review_requested",
        "other"
      ]
    },
    "timing_review_flag_status": {
      "type": "string",
      "enum": [
        "open",
        "snoozed",
        "resolved",
        "dismissed"
      ]
    },
    "severity": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    }
  }
}
