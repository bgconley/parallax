# Parallax local development environment

PARALLAX_ENV=local
PARALLAX_PUBLIC_BASE_URL=https://api.parallax.local
PARALLAX_DATABASE_URL=postgresql://parallax:parallax_dev_password@postgres:5432/parallax
PARALLAX_REDIS_URL=redis://redis:6379/0
PARALLAX_TEMPORAL_ADDRESS=temporal:7233
PARALLAX_TEMPORAL_NAMESPACE=default

PARALLAX_OBJECT_STORAGE_ENDPOINT=http://minio:9000
PARALLAX_OBJECT_STORAGE_ACCESS_KEY=parallax_dev
PARALLAX_OBJECT_STORAGE_SECRET_KEY=parallax_dev_password
PARALLAX_OBJECT_STORAGE_BUCKET_RAW=parallax-raw
PARALLAX_OBJECT_STORAGE_BUCKET_EXPORTS=parallax-exports
PARALLAX_OBJECT_STORAGE_BUCKET_ARTIFACTS=parallax-artifacts

PARALLAX_AUTH_JWT_ISSUER=https://auth.parallax.local
PARALLAX_AUTH_JWT_AUDIENCE=parallax-api
PARALLAX_AUTH_DEV_BYPASS=true

PARALLAX_ALLOW_CLOUD_LLM_FALLBACK=false
PARALLAX_RETAIN_AUDIO_DEFAULT=false
PARALLAX_LOG_RAW_CONTEXT=false

PARALLAX_VLLM_CONTEXT_URL=http://vllm-context:8000
PARALLAX_VLLM_NARRATOR_URL=http://vllm-narrator:8000
PARALLAX_EMBEDDINGS_URL=http://tei-embeddings:80

POSTGRES_DB=parallax
POSTGRES_USER=parallax
POSTGRES_PASSWORD=parallax_dev_password
MINIO_ROOT_USER=parallax_dev
MINIO_ROOT_PASSWORD=parallax_dev_password
